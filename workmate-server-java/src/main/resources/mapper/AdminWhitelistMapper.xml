<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.workmate.server.mapper.AdminWhitelistMapper">

    <resultMap id="BaseResultMap" type="com.workmate.server.entity.AdminWhitelist">
        <id column="id" property="id"/>
        <result column="rule_type" property="ruleType"/>
        <result column="rule_value" property="ruleValue"/>
        <result column="remark" property="remark"/>
        <result column="is_active" property="isActive"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="findByIsActiveTrue" resultMap="BaseResultMap">
        SELECT * FROM admin_whitelist WHERE is_active = true
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO admin_whitelist (rule_type, rule_value, remark, is_active, created_at)
        VALUES (#{ruleType}, #{ruleValue}, #{remark}, #{isActive}, #{createdAt})
    </insert>

    <delete id="deleteById">
        DELETE FROM admin_whitelist WHERE id = #{id}
    </delete>

    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM admin_whitelist WHERE id = #{id}
    </select>

    <update id="update">
        UPDATE admin_whitelist
        SET rule_type = #{ruleType}, rule_value = #{ruleValue}, remark = #{remark}, is_active = #{isActive}
        WHERE id = #{id}
    </update>

    <select id="findAll" resultMap="BaseResultMap">
        SELECT * FROM admin_whitelist ORDER BY created_at DESC
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM admin_whitelist
    </select>

</mapper>
