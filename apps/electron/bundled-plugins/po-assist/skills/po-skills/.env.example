# ===== DPMP 配置 =====
#
# 这一组配置主要用于：
# - story-create
# - quick-story
#
# 如果你当前只使用 Wiki 转 Markdown、PRD 结构化，不创建 DPMP Story，
# 可以先不配置 DPMP 相关字段。

# DPMP_COOKIE
# 作用：
# - 作为登录态，供脚本调用 DPMP 接口时使用
#
# 获取方式：
# 1. 浏览器打开 http://pt.htsc 并登录
# 2. 按 F12 打开开发者工具
# 3. 切到 Network 标签
# 4. 刷新页面或执行任意操作，点开任意一个发往 pt.htsc 的请求
# 5. 在 Headers 中找到 Cookie 字段
# 6. 复制 Cookie: 后面的完整值，粘贴到下面这一行
#
# 注意：
# - 这里要的是完整 Cookie 字符串，不是其中某一个 token
# - Cookie 通常会过期，失效后需要重新复制
# - 请保持一整行，不要换行
#
# 截图占位：
# - [截图占位：DPMP 登录页]
# - [截图占位：开发者工具 Network 标签]
# - [截图占位：请求 Headers 中 Cookie 字段]
DPMP_COOKIE=menuversion=2; sensorsdata2015jssdkcross=...; token=...; accessToken=...; refreshToken=...

# DPMP_PROJECT_ID
# 作用：
# - 指定 Story 创建到哪个 DPMP 项目
#
# 获取方式：
# - 打开目标 DPMP 项目页面
# - 从页面 URL 或项目信息中找到项目 ID
#
# 注意：
# - 示例值 2232 只是默认值，请按你们团队实际项目替换
#
# 截图占位：
# - [截图占位：DPMP 项目页面中的 project id]
DPMP_PROJECT_ID=2232

# DPMP_TASK_TYPE_ID
# 作用：
# - 指定创建任务的类型
#
# 默认值：
# - 13 表示标准 Story，通常保持默认即可
#
# 什么时候需要改：
# - 只有你们团队的 DPMP 类型配置不同，才需要修改
DPMP_TASK_TYPE_ID=13

# DPMP_BASE_URL
# 作用：
# - DPMP 接口基础地址
#
# 是否需要修改：
# - 通常不需要，除非后端接口地址变更
DPMP_BASE_URL=http://pt.htsc/paas/dc/api

# DPMP_REQUEST_DELAY
# 作用：
# - 批量创建 Story 时，每次请求之间等待的秒数
#
# 为什么需要：
# - 避免请求过快触发限流，或导致接口不稳定
#
# 建议：
# - 通常使用默认值 3
# - 如果批量创建时被限流，可以适当调大
DPMP_REQUEST_DELAY=3

# ===== Confluence Wiki 配置 =====
#
# 这一组配置主要用于：
# - doc-convert --url

# HTSC_WIKI_TOKEN
# 作用：
# - 访问 Confluence Wiki 页面内容
#
# 获取方式：
# 1. 登录 Confluence Wiki
# 2. 点击右上角头像
# 3. 进入“个人设置”
# 4. 找到“个人访问令牌”或 Personal Access Tokens
# 5. 创建新的 Token
# 6. 复制 Token，填到下面这一行
#
# 注意：
# - 这里需要的是 Wiki Personal Access Token，不是浏览器 Cookie
# - Token 通常只在创建时完整展示一次，建议立刻保存
#
# 截图占位：
# - [截图占位：Wiki 头像入口]
# - [截图占位：个人设置页面]
# - [截图占位：Personal Access Tokens 页面]
# - [截图占位：Token 创建完成后的复制位置]
HTSC_WIKI_TOKEN=your_personal_access_token_here

# ===== 说明 =====
#
# 1. DPMP 是内网服务，脚本会自动绕过企业代理（http_proxy/https_proxy）直连。
# 2. 如果访问失败，请先确认：
#    - 当前网络可以访问 pt.htsc / wiki.htzq.htsc.com.cn
#    - Cookie 或 Token 是最新且完整的
# 3. .env 文件中通常包含敏感信息，不要提交到 git。
