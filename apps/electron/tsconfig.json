{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/renderer/*"],
      "@/types/*": ["./src/types/*"],
      "@/auth": ["./src/auth"],
      "@/auth/*": ["./src/auth/*"],
      "@/models": ["./src/models"],
      "@/models/*": ["./src/models/*"],
      "@/platform-models": ["./src/platform-models"],
      "@/platform-models/*": ["./src/platform-models/*"]
    }
  },
  "include": ["src/**/*"]
}
