{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/renderer/*"],
      "@/types/*": ["./src/types/*"],
      "@/auth": ["./src/auth"],
      "@/auth/*": ["./src/auth/*"],
      "@/models": ["./src/models"],
      "@/models/*": ["./src/models/*"]
    }
  },
  "include": ["src/**/*"]
}
