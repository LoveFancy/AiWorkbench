# ===== DPMP API 配置 - openApiToken 认证 =====
#
# 将此文件复制为 .env：
#   cp .env.example .env
#
# 如果你不清楚某个字段怎么填，可以运行以下命令检测当前配置状态：
#   python3 run.py check-config

# ============================================
# 必需配置（缺少以下任一配置将无法使用）
# ============================================

# DPMP_BASE_URL
# 作用：
# - DPMP API 基础地址，所有接口请求的根路径
#
# 是否需要修改：
# - 通常不需要，除非后端接口地址变更
#
# 默认值：
# - http://10.102.104.177:8080
DPMP_BASE_URL=http://10.102.104.177:8080

# DPMP_APP_ID
# 作用：
# - 应用ID，用于标识调用方身份
#
# 获取方式：
# - 从 DPMP 系统管理员获取
#
# 默认值：
# - 18
DPMP_APP_ID=20260518

# DPMP_OPEN_API_TOKEN
# 作用：
# - API Token，用于 openApiToken 认证方式调用 DPMP 接口
#
# 获取方式：
# - 联系马振徽(011516) 获取
#
# 注意：
# - 这里需要的是 openApiToken，不是浏览器 Cookie
# - Token 通常只在创建时完整展示一次，请立刻保存
# - 如果 Token 泄露或过期，需要联系管理员重新生成
DPMP_OPEN_API_TOKEN=<your_token>

# DPMP_AD_ACCOUNT
# 作用：
# - 操作人工号（AD账号），用于标识谁在执行操作
#
# 获取方式：
# - 就是你的工号，一般是 6 位数字
#
# 示例：
# - 012950
# - 021343
DPMP_AD_ACCOUNT=<your_ad_account>

# ============================================
# 可选配置（有默认值，可按需修改）
# ============================================

# DPMP_REQUEST_TIMEOUT
# 作用：
# - 调用 DPMP 接口时的等待超时时间（秒）
#
# 建议：
# - 通常使用默认值 30
# - 如果接口响应较慢，可以适当调大
DPMP_REQUEST_TIMEOUT=30

# DPMP_PRODUCT_KEY
# 作用：
# - 产品空间key，创建 REQ（需求）时指定归属的产品空间
# - 支持多个 key，用英文分号 ; 分隔
#
# 获取方式：
# - 打开 DPMP 系统中对应产品空间的页面，查看 URL 或页面信息中的 key 值
#
# 示例：
# - 单个：PRODU
# - 多个：PRODU;S0305;FINANCE
#
# 注意：
# - 如果只配置一个 key，AI 会自动使用
# - 如果配置多个 key，AI 会列出让你选择
# - 不配置则需要每次手动输入
#
# 截图占位：
# - [截图占位：DPMP 产品空间页面中的 product key]
DPMP_PRODUCT_KEY=PRODU

# DPMP_PROJECT_KEY
# 作用：
# - 项目空间key，创建 STORY（任务）时指定归属的项目空间
# - 支持多个 key，用英文分号 ; 分隔
#
# 获取方式：
# - 打开 DPMP 系统中对应项目空间的页面，查看 URL 或页面信息中的 key 值
#
# 示例：
# - 单个：TEST0408
# - 多个：TEST0408;TEST0409;PROJ01
#
# 注意：
# - 如果只配置一个 key，AI 会自动使用
# - 如果配置多个 key，AI 会列出让你选择
# - 不配置则需要每次手动输入
#
# 截图占位：
# - [截图占位：DPMP 项目空间页面中的 project key]
DPMP_PROJECT_KEY=TEST0408

# ============================================
# 安全提示
# ============================================
# - .env 文件已在 .gitignore 中配置，不会被提交到版本控制系统
# - 不要将 .env 文件中的 Token 发给任何人
# - 不要在对话中公开讨论或分享 Token 明文
# - Token 泄露后应立即在 DPMP 系统中重新生成
