{
  "type":"mcp",
  "displayName": "华泰邮箱",
  "description": "华泰证券企业邮箱 IMAP 只读连接器，使用 WorkMate 内置邮箱 MCP",
  "category": "邮件服务",
  "status": "available",
  "serverName": "huatai-email",
  "version": "1.0.2",
  "sortOrder": 1,
  "disabledTools": [
    "add_email_account",
    "send_email",
    "save_to_mailbox",
    "delete_emails",
    "delete_email",
    "mark_emails_as_read",
    "move_emails",
    "archive_emails",
    "download_attachment"
  ],
  "mcpServer": {
    "type": "stdio",
    "command": "__WORKMATE_ELECTRON__",
    "args": ["__CONNECTOR_RUNTIME__/email-server.cjs", "stdio"],
    "env": {
      "ELECTRON_RUN_AS_NODE": "1",
      "MCP_EMAIL_SERVER_ACCOUNT_NAME": "htsc",
      "MCP_EMAIL_SERVER_EMAIL_ADDRESS": "",
      "MCP_EMAIL_SERVER_PASSWORD": "",
      "MCP_EMAIL_SERVER_FULL_NAME": "",
      "MCP_EMAIL_SERVER_USER_NAME": "",
      "MCP_EMAIL_SERVER_IMAP_HOST": "htemail.htsc.com.cn",
      "MCP_EMAIL_SERVER_IMAP_PORT": "993",
      "MCP_EMAIL_SERVER_IMAP_SSL": "true"
    }
  }
}
