{
  "runtime": {
    "type": "node",
    "version": ">=20"
  },
  "init": {
    "darwin": "npm install -g @ht/talents",
    "linux": "npm install -g @ht/talents",
    "win32": "npm install -g @ht/talents"
  },
  "versionCheck": {
    "command": {
      "darwin": "talents -V",
      "linux": "talents -V",
      "win32": "talents.cmd -V"
    },
    "minVersion": "1.0.0"
  },
  "userProvidedData": [],
  "status": {
    "darwin": "talents workspace --json",
    "linux": "talents workspace --json",
    "win32": "talents.cmd workspace --json"
  },
  "env": {
    "HTSKILL_TOKEN": "{{HTSKILL_TOKEN}}",
    "AGENTOS_ENV": "uat"
  }
}
