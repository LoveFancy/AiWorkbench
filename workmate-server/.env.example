# 服务端口
PORT=3000

# 数据库连接（MySQL）
DATABASE_URL="mysql://root:password@localhost:3306/workmate_server"

# AES-128-GCM 密钥（16字节 Hex），EIP 网关与后端共享
USER_ID_ENCRYPTION_KEY=""

# 大模型平台 API（实时查询模型列表）
MODEL_PLATFORM_API_URL="https://model-platform.example.com/api/v1/models"
MODEL_PLATFORM_API_KEY="your-api-key"
MODEL_PLATFORM_TIMEOUT_MS="10000"

# 日志级别（debug | info | warn | error）
LOG_LEVEL="info"

# CORS 允许的来源（多个用逗号分隔）
CORS_ORIGIN="http://localhost:5173"

# ===== 用户身份校验开关（测试环境关闭） =====
REQUIRE_USER_ID=false
DEFAULT_USER_ID=test_user

# 初始管理员工号（逗号分隔，仅 prisma/seed.ts 首次使用）
ADMIN_JOB_IDS="022480"
